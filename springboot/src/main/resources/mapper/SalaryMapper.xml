<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.timsm.demo.mapper.SalaryMapper">
<select id="findSalaryListByEmpNo" parameterType="String" resultType="com.timsm.demo.dto.SalaryDTO">
    SELECT *
    FROM C_PAYLIST
    WHERE EMP_NO = #{empNo}
    ORDER BY PAY_YM DESC
</select>
</mapper>