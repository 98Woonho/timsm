<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.timsm.demo.mapper.UserMapper">
    <select id="findUserByIdAndPass" parameterType="com.timsm.demo.dto.LoginRequestDTO" resultType="map">
        SELECT USER_ID
        , USER_NAME
        FROM   CM_USERS
        WHERE  USER_ID   = #{userId}
        AND    USER_PASS = #{userPass}
    </select>
</mapper>